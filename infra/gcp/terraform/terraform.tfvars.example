project_id     = "your-gcp-project-id"
project_number = "000000000000"
region         = "us-central1"
zone           = "us-central1-a"
environment    = "prod"
github_repo    = "owner/name"

# All-in-one VM sizing
machine_type   = "e2-standard-8"
boot_disk_size = 40
data_disk_size = 100

# Public exposure
domain                = ""
ssh_source_ranges     = ["0.0.0.0/0"]
backend_allowed_hosts = "*"
