# Reverse proxy for the all-in-one VM. Caddy terminates TLS (auto Let's Encrypt
# when a real domain is set) and routes by path to the web + api containers.
#
# APP_SITE is injected by startup.sh: the app hostname (e.g. "app.apilens.ai")
# or ":80" before a domain exists. On the app host:
#   /api/v1/*, /admin/*, /static/*, /media/*  -> Django backend
#   everything else (incl. the Next.js /api/* route handlers)  -> Next.js
#
# IMPORTANT: only /api/v1/* goes to Django. The Next.js app has its OWN server
# route handlers under /api/* (e.g. /api/auth/magic-link, /api/projects) that
# proxy to Django server-side via DJANGO_API_URL. Routing all of /api/* to
# Django would 404 every one of those — which breaks the whole UI.
#
# When a dedicated API hostname (API_SITE, e.g. "api.apilens.ai") is configured,
# startup.sh APPENDS a second site block below that proxies everything to the
# backend EXCEPT /ingest/* (404'd — ingestion lives on its own host). It's
# appended (not kept here) so an empty API_SITE doesn't leave an invalid empty
# site label.
#
# When a dedicated ingestion hostname (INGEST_SITE, e.g. "ingest.apilens.ai") is
# configured, startup.sh APPENDS a third site block that rewrites the public
# /v1/* path onto Django's /ingest/v1/* mount and proxies to the backend. This
# keeps high-volume SDK traffic off the dashboard API host.

{$APP_SITE} {
	encode gzip zstd

	# Identity (IAM) service — served under app.apilens.ai instead of a separate
	# auth.* host. OIDC discovery + JWKS live at the well-known root (so the
	# issuer = https://app.apilens.ai), and the auth API is under /auth/v1/*
	# (rewritten onto the service's canonical /v1/*).
	handle /.well-known/openid-configuration {
		reverse_proxy identity:8000
	}
	handle /.well-known/jwks.json {
		reverse_proxy identity:8000
	}
	handle /auth/v1/* {
		uri replace /auth/v1 /v1
		reverse_proxy identity:8000
	}

	# Core control-plane API + Django admin/static/media.
	@core path /api/v1/* /admin/* /static/* /media/*
	handle @core {
		reverse_proxy api:8000
	}

	# Everything else: the Next.js app + its OWN server route handlers under
	# /api/* (e.g. /api/auth/magic-link, /api/account/*, /api/projects) which
	# proxy to the services server-side. Routing those to Django would 404 them.
	handle {
		reverse_proxy web:3000
	}
}
